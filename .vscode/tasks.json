				// "${workspaceFolder}/zephyr/samples/subsys/usb_c/sink",
				// "-DZEPHYR_BASE=${workspaceFolder}/zephyr",
				// "-DDTC_OVERLAY_FILE=${workspaceFolder}/zephyr/samples/subsys/logging/logger/segger_uart_rtt.overlay",
				// "-DEXTRA_CONF_FILE=${workspaceFolder}/zephyr/snippets/rtt-console/rtt-console.conf"
			],
			"problemMatcher": [
				"$gcc"
			]
